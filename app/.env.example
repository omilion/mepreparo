# Copia este archivo a .env.local y pega tu clave real ahí.
# .env.local NO se sube a git (está en .gitignore).

# Clave de Google Gemini. Consíguela en https://aistudio.google.com/apikey
# Suele empezar con "AIza..."
GEMINI_API_KEY=

# Modelo de chat del tutor (económico). Ver docs/ARQUITECTURA-tecnica.md §6
GEMINI_MODEL=gemini-2.5-flash-lite

# Secreto HMAC del diagnostico (genera uno: python -c "import secrets; print(secrets.token_hex(32))")
DIAG_HMAC_SECRET=

# Herramientas de desarrollo (panel dev flotante + botones dev·sopa/dev·ejercicio
# dentro del chat del tutor). En local siempre están activas. Para verlas en el
# VPS de staging, poner "1" ANTES de "npm run build" (las vars NEXT_PUBLIC_ se
# inlinean en build time, no en runtime). ⚠️ Al lanzar con usuarios reales,
# dejarla en "0" o quitarla para no exponer estos controles a los niños.
NEXT_PUBLIC_DEV_TOOLS=0
